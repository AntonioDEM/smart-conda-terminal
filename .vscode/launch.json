{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/**/*.js"
      ],
      "env": {
        "VSCODE_DEBUG_MODE": "true",
        "SMART_CONDA_TERMINAL_DEBUG": "true"
      },
      "preLaunchTask": "npm: install",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Run Extension (Production)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Extension Tests",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/test"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/**/*.js",
        "${workspaceFolder}/test/**/*.js"
      ]
    }
  ]
}